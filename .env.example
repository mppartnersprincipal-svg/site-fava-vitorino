# URL pública do site (usada em metadata, sitemap e JSON-LD)
NEXT_PUBLIC_SITE_URL=https://favaevitorino.com.br

# Google Analytics 4 — ID de medição (ex.: G-XXXXXXXXXX). Sem valor, o script não é renderizado.
NEXT_PUBLIC_GA4_ID=

# Meta Pixel — ID numérico. Sem valor, o script não é renderizado.
NEXT_PUBLIC_META_PIXEL_ID=
